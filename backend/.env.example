# Google Cloud / Firebase
GOOGLE_CLOUD_PROJECT=myhack-bf3ce
FIRESTORE_DATABASE=myhack

# Gemini API (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key-here

# Vertex AI region (for embeddings)
VERTEX_AI_LOCATION=us-central1

# Optional: path to service account JSON (if not using gcloud auth)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
